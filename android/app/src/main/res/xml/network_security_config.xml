<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Only trust our specific backend domain. Prevents MITM attacks. -->
  <!-- Phase 21 adds certificate pinning hashes here. -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">havenly.solutions</domain>
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </domain-config>
</network-security-config>
