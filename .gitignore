android/captures/
*.jks
*.keystore

# iOS generated
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
ios/Runner.xcworkspace/
ios/*.xcworkspace/
.ios/

# Environment — never commit secrets
.env
.env.local
.env.production
.env.development
google-services.json
GoogleService-Info.plist
firebase_options.dart

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db
